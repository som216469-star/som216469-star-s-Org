# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The API URL of your Supabase project (e.g. https://xxx.supabase.co)
SUPABASE_URL=""

# SUPABASE_KEY: The public anon/service_role API key for your Supabase project
SUPABASE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InF2YnF6Znh3ZXlya3ptam1ob2FzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzNDA1ODQsImV4cCI6MjA5NzkxNjU4NH0.cxKE83nUtGjwfjpSC51vKN6PfuyCqPyfeuYUetZU-dc"

# SMTP Email Configuration (For Sending OTP Codes)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="School Pro <your-email@gmail.com>"

